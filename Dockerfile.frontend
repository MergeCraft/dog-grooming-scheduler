# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy solution and package management files
COPY DogGrommingScheduler/Directory.Packages.props DogGrommingScheduler/
COPY DogGrommingScheduler/DogGrommingScheduler.slnx DogGrommingScheduler/

# Copy project files
COPY DogGrommingScheduler/BlazorClient/BlazorClient.csproj DogGrommingScheduler/BlazorClient/
COPY DogGrommingScheduler/Shared/Shared.csproj DogGrommingScheduler/Shared/
COPY DogGrommingScheduler/BusinessLogic/BusinessLogic.csproj DogGrommingScheduler/BusinessLogic/

# Restore dependencies
RUN dotnet restore DogGrommingScheduler/BlazorClient/BlazorClient.csproj

# Copy source code
COPY DogGrommingScheduler/BlazorClient/ DogGrommingScheduler/BlazorClient/
COPY DogGrommingScheduler/Shared/ DogGrommingScheduler/Shared/
COPY DogGrommingScheduler/BusinessLogic/ DogGrommingScheduler/BusinessLogic/

# Publish Blazor WASM
RUN dotnet publish DogGrommingScheduler/BlazorClient/BlazorClient.csproj -c Release -o /app/publish

# Runtime stage - serve with nginx
FROM nginx:alpine AS runtime

# Copy published Blazor files to nginx
COPY --from=build /app/publish/wwwroot /usr/share/nginx/html

# nginx config for Blazor WASM routing
RUN echo 'server { \
    listen 80; \
    location / { \
        root /usr/share/nginx/html; \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80
