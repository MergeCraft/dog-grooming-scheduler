@page "/"
@using System.ComponentModel.DataAnnotations

<PageTitle>Login</PageTitle>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body">
          <h3 class="card-title mb-3">Sign in</h3>

          @if (!string.IsNullOrEmpty(errorMessage))
          {
            <div class="alert alert-danger" role="alert">
              @errorMessage
            </div>
          }
          else if (loginSuccess)
          {
            <div class="alert alert-success" role="alert">
              Redirecting to dashboard...
            </div>
          }

          <EditForm Model="loginModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
              <label class="form-label">Email</label>
              <InputText class="form-control" type="email" @bind-Value="loginModel.Email" />
              <ValidationMessage For="@(() => loginModel.Email)" />
            </div>

            <div class="mb-3">
              <label class="form-label">Password</label>
              <InputText class="form-control" type="password" @bind-Value="loginModel.Password" />
              <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <div class="form-check mb-3">
              <InputCheckbox class="form-check-input" @bind-Value="loginModel.RememberMe" />
              <label class="form-check-label">Remember me</label>
            </div>

            <div class="d-flex align-items-center justify-content-between">
              <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                  <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                  <span class="ms-2">Signing in...</span>
                }
                else
                {
                  <span>Sign in</span>
                }
              </button>

            </div>
            <div class="d-flex align-items-center justify-content-between">
              <NavLink class="btn btn-link" href="registro">Don't have an account? Sign up here</NavLink>
            </div>
          </EditForm>
        </div>
      </div>
    </div>
  </div>
</div>

@code {
    // Local view model for the login form (temporary DTO)
    private LoginModel loginModel = new();

    // UI state
    private bool isSubmitting;
    private bool loginSuccess;
    private string? errorMessage;

    // Handle valid form submission (client-side simulation only)
    private async Task HandleValidSubmit()
    {
        // Reset state
        errorMessage = null;
        loginSuccess = false;
        isSubmitting = true;

        // Simulate server processing
        await Task.Delay(1000);

        // Simulate authentication: only a specific demo credential succeeds
        // Security rule: on failure, provide a generic error message
        if (string.Equals(loginModel.Email?.Trim(), "demo@demo.com", StringComparison.OrdinalIgnoreCase)
            && loginModel.Password == "Password123")
        {
            loginSuccess = true;
        }
        else
        {
            errorMessage = "Incorrect email or password.";
            loginSuccess = false;
        }

        isSubmitting = false;
    }

    // Temporary DTO used for binding and validation
    public class LoginModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "The email is not a valid email address.")]
        public string? Email { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        public string? Password { get; set; }

        public bool RememberMe { get; set; }
    }
}
