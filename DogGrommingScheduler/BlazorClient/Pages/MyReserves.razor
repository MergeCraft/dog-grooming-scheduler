@page "/mis-reservas"
@using Microsoft.AspNetCore.Authorization
@using Shared.DTOs
@using BlazorClient.Services
@using System.Security.Claims
@using Shared.DTOs.ReserveDto
@attribute [Authorize]
@inject ReserveService ReserveService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Mis Reservas</PageTitle>

<div class="container mt-4">
    <h3 class="mb-4"><i class="bi bi-list-stars"></i> Mis Reservas</h3>

    @if (reserves == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Cargando tus citas...</p>
        </div>
    }
    else if (!reserves.Any())
    {
        <div class="alert alert-info">
            Aún no tienes reservas programadas. ¡Anímate a agendar una!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var res in reserves)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card @(res.IsCanceled ? "border-danger opacity-75" : "border-primary") shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title text-primary">
                                    <i class="bi bi-calendar-event"></i> @res.ReservationDate.ToShortDateString()
                                </h5>
                                @if (res.IsCanceled)
                                {
                                    <span class="badge bg-danger">Cancelada</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                            </div>

                            <p class="card-text mb-1"><strong>Hora:</strong> @res.TimeSlot.ToString(@"hh\:mm") hs</p>
                            <p class="card-text mb-3"><strong>Tamaño Mascota:</strong> @res.PetSize</p>

                            @if (!res.IsCanceled && res.ReservationDate >= DateTime.Today)
                            {
                                <button class="btn btn-outline-danger btn-sm w-100"
                                        @onclick="() => HandleCancel(res.Id)">
                                    <i class="bi bi-x-circle"></i> Cancelar Reserva
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<MyReserveDto>? reserves;

    protected override async Task OnInitializedAsync()
    {
        await LoadReserves();
    }

    private async Task LoadReserves()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (Guid.TryParse(userIdClaim, out var userId))
        {
            reserves = await ReserveService.GetMyReservesAsync(userId);
        }
    }

    private async Task HandleCancel(Guid id)
    {
        var success = await ReserveService.CancelReserveAsync(id);
        if (success)
        {
            await LoadReserves(); 
        }
    }
}
