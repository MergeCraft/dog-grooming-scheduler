@page "/reserve"
@using Microsoft.AspNetCore.Authorization
@using Shared.DTOs
@using Shared.DTOs.PetGroomerDtos
@using BlazorClient.Services
@inject PetGroomerService PetGroomerService
@attribute [Authorize]

<PageTitle>Reserve</PageTitle>

<div class="container mt-4">
    <h3 class="mb-4">Select a Professional</h3>

    @if (groomers == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading professionals...</p>
        </div>
    }
    else
    {
        @* PASO 1: Selección de Groomer *@
        <div class="row">
            @foreach (var groomer in groomers)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100 shadow-sm @(selectedGroomerId == groomer.Id ? "border-primary bg-light" : "")"
                         @onclick="() => SelectGroomer(groomer.Id)"
                         style="cursor: pointer; transition: 0.3s;">
                        <div class="card-body text-center">
                            <div class="bi bi-person-badge-fill mb-2" style="font-size: 2rem; color: #6c757d;"></div>
                            <h5 class="card-title">@groomer.Name</h5>
                            <p class="card-text text-muted small">Professional Groomer</p>
                            @if (selectedGroomerId == groomer.Id)
                            {
                                <span class="badge bg-primary text-white">Selected</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @* PASO 2: Selección de Fecha y Horarios (Solo si hay un groomer seleccionado) *@
        @if (selectedGroomerId != Guid.Empty)
        {
            <div class="mt-4 p-4 border rounded bg-white shadow-sm">
                <h4 class="mb-3">Select Date & Time for @groomers.First(g => g.Id == selectedGroomerId).Name</h4>

                <div class="row">
                    <div class="col-md-4">
                        <label class="form-label">Choose a Date</label>
                        <input type="date" class="form-control"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")"
                               @onchange="OnDateChanged" />
                    </div>
                </div>

                @if (isLoadingSchedule)
                {
                    <div class="mt-4 text-center">
                        <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                        <span> Checking availability...</span>
                    </div>
                }
                else if (selectedSchedule != null)
                {
                    <div class="mt-4">
                        <h5>Available Slots</h5>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var slot in GenerateSlots())
                            {
                                <button class="btn @(selectedTime == slot ? "btn-primary" : "btn-outline-primary")"
                                        @onclick="() => selectedTime = slot">
                                    @slot.ToString(@"hh\:mm")
                                </button>
                            }
                        </div>

                        @if (selectedTime != null)
                        {
                            <div class="mt-4 p-3 bg-light rounded border border-primary text-center">
                                <p class="mb-2"><strong>Summary:</strong> @selectedDate.ToShortDateString() at @selectedTime.Value.ToString(@"hh\:mm")</p>
                                <button class="btn btn-success px-5" @onclick="ConfirmAppointment">Confirm Appointment</button>
                            </div>
                        }
                    </div>
                }
                else if (hasSearched)
                {
                    <div class="alert alert-warning mt-4">
                        No available schedule found for this professional on the selected date.
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<PetGroomerDto>? groomers;
    private Guid selectedGroomerId = Guid.Empty;

    // Variables para la lógica de horarios
    private ScheduleDto? selectedSchedule;
    private bool isLoadingSchedule = false;
    private bool hasSearched = false;
    private DateTime selectedDate;
    private TimeSpan? selectedTime;

    protected override async Task OnInitializedAsync()
    {
        groomers = await PetGroomerService.GetAllGroomersAsync();
    }

    private void SelectGroomer(Guid id)
    {
        selectedGroomerId = id;
        selectedSchedule = null; // Reset al cambiar de profesional
        hasSearched = false;
        selectedTime = null;
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            selectedTime = null;
            isLoadingSchedule = true;
            hasSearched = true;

            // Llamada al nuevo método que agregaste en el Service
            selectedSchedule = await PetGroomerService.GetScheduleAsync(selectedGroomerId, date);

            isLoadingSchedule = false;
        }
    }

    private List<TimeSpan> GenerateSlots()
    {
        if (selectedSchedule == null) return new();

        var slots = new List<TimeSpan>();
        var current = selectedSchedule.StartTime.TimeOfDay;
        var end = selectedSchedule.EndTime.TimeOfDay;

        // Generamos turnos cada 1 hora según tu lógica de negocio
        while (current < end)
        {
            slots.Add(current);
            current = current.Add(TimeSpan.FromHours(1));
        }
        return slots;
    }

    private async Task ConfirmAppointment()
    {
        // Aquí iría la lógica para enviar el CreateReserveDto a tu ReserveController
        Console.WriteLine($"Reserva confirmada para {selectedDate} a las {selectedTime}");
    }
}